# ─────────────────────────────────────────────
# LLM Provider
# Options: "gemini" | "llama" | "openai" | "mock"
# ─────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini — free via Google AI Studio (https://aistudio.google.com/apikey)
# Default model: gemini-1.5-pro (thesis H2 comparison model)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Llama 3 — via local Ollama (https://ollama.com) or compatible OpenAI-format endpoint
# Default: http://localhost:11434 with model llama3
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Database (PostgreSQL 16 + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/scholaragent

# ─────────────────────────────────────────────
# Web Search
# ─────────────────────────────────────────────
TAVILY_API_KEY=

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# ─────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
