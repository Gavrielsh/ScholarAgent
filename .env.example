# ─────────────────────────────────────────────
# LLM Provider
# Options: "gemini" | "llama" | "openai" | "mock"
# ─────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini — free via Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Llama 3 — via local Ollama or compatible OpenAI-format endpoint
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Database (PostgreSQL 16 + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/scholaragent
PG_POOL_MAX=10

# ─────────────────────────────────────────────
# Web Search
# ─────────────────────────────────────────────
TAVILY_API_KEY=

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# ─────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ─────────────────────────────────────────────
# Local file storage
# ─────────────────────────────────────────────
# Where chat conversations are persisted, one JSON file per sender phone.
CHAT_HISTORY_DIR=./data/chats
