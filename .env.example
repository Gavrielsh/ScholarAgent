# LLM Provider: "gemini" | "openai" | "mock"
LLM_PROVIDER=gemini

# Google Gemini (free tier via Google AI Studio — https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional: override model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Tavily web search
TAVILY_API_KEY=

# PostgreSQL with pgvector
DATABASE_URL=postgresql://user:password@localhost:5432/scholaragent

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
